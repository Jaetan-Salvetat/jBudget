<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

        <LinearLayout
            android:id="@+id/container"
            android:layout_width="match_parent"
            android:layout_height="49dp"
            android:orientation="horizontal"
            android:paddingStart="10dp"
            android:gravity="center_vertical">

            <!--<CheckBox
                android:id="@+id/history_item_checked"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>-->

            <TextView
                android:id="@+id/history_item_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:textSize="18sp"
                android:layout_weight="1"
                android:text="@string/desc"/>

            <TextView
                android:id="@+id/history_item_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="18sp"
                android:textStyle="bold"
                android:minWidth="100dp"
                android:textAlignment="textEnd"
                android:text="@string/desc"/>

            <TextView
                android:id="@+id/euro"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="18sp"
                android:text="@string/euro"/>

            <ImageButton
                android:id="@+id/remove_history_item_btn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:padding="10dp"
                android:background="@drawable/error_icon_btn_ripple_effect"
                android:src="@drawable/ic_baseline_delete_forever"
                android:contentDescription="@string/desc" />

        </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>