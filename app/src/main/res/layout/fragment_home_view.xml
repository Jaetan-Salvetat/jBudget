<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".HomeViewFragment">

    <androidx.appcompat.widget.Toolbar
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="13"
                android:textStyle="bold"
                android:text="@string/title_appbar_home"
                android:textSize="22sp"/>

            <ImageButton
                android:id="@+id/go_to_settings_btn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/sample_icon_btn_ripple_effect"
                android:padding="10dp"
                android:layout_marginEnd="10dp"
                android:src="@drawable/ic_baseline_settings"
                android:contentDescription="@string/desc" />

        </LinearLayout>

    </androidx.appcompat.widget.Toolbar>

    <ListView
        android:id="@+id/listview_home_budgets"
        android:visibility="invisible"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:divider="@android:color/transparent"
        android:dividerHeight="10dp"
        android:layout_marginTop="60dp"
        android:paddingHorizontal="10dp"
        android:layout_marginBottom="20dp"/>

    <LinearLayout
        android:id="@+id/home_no_budgets"
        android:visibility="visible"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:paddingHorizontal="40dp"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textAlignment="center"
            android:textStyle="italic"
            android:textSize="18sp"
            android:text="@string/no_budget_home"/>

    </LinearLayout>
</FrameLayout>