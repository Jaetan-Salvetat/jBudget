<resources>
<!-- Base application theme. -->
<style name="Theme.JBudget" parent="Theme.Material3.Dark.NoActionBar">
        <!-- Primary color. -->
        <item name="colorPrimary">@color/dark_pink</item>
        <item name="colorOnPrimary">@color/dark_background</item>
        <item name="android:colorPrimaryDark">@color/dark_background</item> <!-- statusBar -->

        <!-- Secondary color. -->
        <item name="colorSecondary">@color/white</item>
        <item name="colorSecondaryVariant">@color/dark_pink</item>

        <!-- Surface color. -->
        <item name="colorSurface">@color/dark_background</item> <!-- toolbar -->

        <!-- Background color. -->
        <item name="backgroundColor">@color/dark_background</item>

        <!-- Control color. -->
        <item name="colorControlHighlight">@color/dark_cyan</item> <!-- ripple color -->
    </style>



    <style name="Theme.ElevatedButton" parent="Widget.Material3.Button.ElevatedButton">
        <item name="backgroundTint">@color/dark_cyan</item>
        <item name="rippleColor">@color/dark_pink</item>
    </style>

    <style name="Theme.OutlinedButton" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeColor">@color/dark_cyan</item>
        <item name="android:textColor">@color/dark_cyan</item>
        <item name="rippleColor">@color/dark_cyan</item>
    </style>


    <style name="Theme.TextButton" parent="Widget.Material3.Button.TextButton">
        <item name="android:textColor">@color/dark_cyan</item>
        <item name="rippleColor">@color/dark_cyan</item>
    </style>

    <style name="Theme.Dialog" parent="@android:style/Theme.Dialog">
        <item name="colorPrimary">@color/dark_cyan</item>
    </style>

    <style name="Theme.CheckBox" parent="Widget.Material3.CompoundButton.CheckBox">
        <item name="buttonTint">@color/dark_cyan</item>
    </style>
</resources>